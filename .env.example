# StewardOS Environment Variables
# Copy to .env.local and fill in values

# App URL (dev: http://localhost:3000, prod: https://stewardos.cc)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Database (Supabase PostgreSQL)
DATABASE_URL=
DIRECT_URL=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM="StewardOS <noreply@stewardos.cc>"

# OpenAI
OPENAI_API_KEY=

# Twilio (SMS)
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Planning Center (People sync)
# OAuth app at https://api.planningcenteronline.com/oauth/applications
PLANNING_CENTER_CLIENT_ID=
PLANNING_CENTER_CLIENT_SECRET=

# Cron (for Vercel cron jobs - set CRON_SECRET)
CRON_SECRET=
